# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files
*.py text
*.md text
*.txt text
*.html text
*.css text
*.js text
*.yml text
*.yaml text
*.json text
*.bat text eol=crlf
*.sh text eol=lf

# Declare binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
